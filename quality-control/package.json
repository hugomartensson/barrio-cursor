{
  "name": "quality-control-agent",
  "version": "1.0.0",
  "description": "Automatic quality controller for Barrio project",
  "type": "module",
  "main": "quality-agent.ts",
  "scripts": {
    "run": "tsx quality-agent.ts",
    "watch": "nodemon --watch ../server/src --watch ../quality-control --exec tsx quality-agent.ts",
    "check": "tsx quality-agent.ts"
  },
  "keywords": [
    "quality-control",
    "code-review",
    "automation"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}