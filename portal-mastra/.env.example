# Gemini (Mastra agents + image validator)
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Places (Maps links + text search)
GOOGLE_PLACES_API_KEY=

# Tavily (optional — search returns empty without key)
TAVILY_API_KEY=

# Portal API (Hugo's account)
PORTAL_EMAIL=
PORTAL_PASSWORD=
PORTAL_API_URL=http://localhost:3000/api

# Supabase (ingest image bucket — create public bucket `ingest-images` or set SUPABASE_INGEST_BUCKET)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# SUPABASE_INGEST_BUCKET=ingest-images

# Persist workflow runs (LibSQL file by default)
# MASTRA_STORAGE_URL=file:./.mastra/mastra.db

# Protect HTTP API (required in production). Express + Telegram send Authorization: Bearer <token>
# If unset, Mastra accepts any request (local dev only).
# MASTRA_SERVER_TOKEN=

# Railway / Docker
# PORT=4111
# HOST=0.0.0.0
