# Gemini (Mastra agents + image validator)
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Places (Maps links + text search)
GOOGLE_PLACES_API_KEY=

# Google Custom Search (image search + web search fallback)
# 1. Enable "Custom Search JSON API" in Google Cloud Console
# 2. Create a search engine at programmablesearchengine.google.com and get its ID (cx)
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Portal API (Hugo's account)
PORTAL_EMAIL=
PORTAL_PASSWORD=
PORTAL_API_URL=http://localhost:3000/api

# Supabase (ingest image bucket — create public bucket `ingest-images` or set SUPABASE_INGEST_BUCKET)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# SUPABASE_INGEST_BUCKET=ingest-images

# Persist workflow runs (LibSQL). Local dev default: ./.mastra/mastra.db
# Railway/Docker: defaults to file:/tmp/mastra.db (ephemeral — survives restarts until redeploy)
# Durable production: Turso — MASTRA_STORAGE_URL=libsql://... + LIBSQL_AUTH_TOKEN
# MASTRA_STORAGE_URL=file:/tmp/mastra.db

# Protect HTTP API (required in production). Express + Telegram send Authorization: Bearer <token>
# If unset, Mastra accepts any request (local dev only).
# MASTRA_SERVER_TOKEN=

# Railway / Docker
# PORT=4111
# HOST=0.0.0.0
