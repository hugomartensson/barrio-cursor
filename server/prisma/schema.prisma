generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

model User {
  id                String   @id // ID comes from Supabase Auth
  email             String   @unique
  passwordHash      String   @map("password_hash")
  name              String
  handle            String?  @unique
  initials          String?
  color             String?
  bio               String?
  cities            String[]
  selectedCity      String?  @map("selected_city")
  profilePictureUrl String?  @map("profile_picture_url")
  isPrivate         Boolean  @default(false) @map("is_private")
  followerCount     Int      @default(0) @map("follower_count")
  followingCount    Int      @default(0) @map("following_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  events           Event[]
  spots            Spot[]
  hostedEvents     Event[]         @relation("EventHost")
  saves            Save[]
  collections      Collection[]
  savedCollections SavedCollection[]
  followers        Follow[]        @relation("following")
  following        Follow[]        @relation("follower")
  requestsSent     FollowRequest[] @relation("FollowRequestsSent")
  requestsReceived FollowRequest[] @relation("FollowRequestsReceived")

  @@index([handle])
  @@map("users")
}

model Spot {
  id           String      @id @default(uuid())
  ownerId      String      @map("owner_id")
  name         String
  description  String?
  address      String
  latitude     Float
  longitude    Float
  categoryTag  String?     @map("category_tag")
  neighborhood String?
  tags         String[]
  saveCount    Int         @default(0) @map("save_count")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  owner User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  media MediaItem[]

  @@index([ownerId])
  @@index([categoryTag])
  // location geometry column with GIST index managed via migration
  @@map("spots")
}

model Event {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  hostId       String?     @map("host_id")
  title        String
  description  String
  category     Category
  categoryTag  String?     @map("category_tag")
  address      String
  neighborhood String?
  latitude     Float
  longitude    Float
  startTime    DateTime    @map("start_time")
  endTime      DateTime?   @map("end_time")
  tags         String[]
  saveCount    Int         @default(0) @map("save_count")
  ticketUrl    String?     @map("ticket_url")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  host  User?       @relation("EventHost", fields: [hostId], references: [id], onDelete: SetNull)
  media MediaItem[]

  @@index([userId])
  @@index([hostId])
  @@index([category])
  @@index([categoryTag])
  @@index([startTime])
  // location geometry column with GIST index managed via migration
  @@map("events")
}

model MediaItem {
  id           String   @id @default(uuid())
  eventId      String?  @map("event_id")
  spotId       String?  @map("spot_id")
  url          String
  type         MediaType
  order        Int      @default(0)
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt    DateTime @default(now()) @map("created_at")

  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  spot  Spot?  @relation(fields: [spotId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([spotId])
  @@map("media_items")
}

model Save {
  userId       String    @map("user_id")
  collectionId String?   @map("collection_id")
  itemType     ItemType  @map("item_type")
  itemId       String    @map("item_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@id([userId, itemType, itemId])
  @@index([userId])
  @@index([collectionId])
  @@index([itemId])
  @@map("saves")
}

model Collection {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  name        String
  description String?
  visibility  CollectionVisibility @default(private)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   CollectionItem[]
  saves   Save[]
  savedBy SavedCollection[]

  @@index([userId])
  @@index([visibility])
  @@map("collections")
}

model SavedCollection {
  userId       String   @map("user_id")
  collectionId String   @map("collection_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, collectionId])
  @@index([userId])
  @@index([collectionId])
  @@map("saved_collections")
}

model CollectionItem {
  id           String   @id @default(uuid())
  collectionId String   @map("collection_id")
  itemType     ItemType @map("item_type")
  itemId       String   @map("item_id")
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
  @@index([itemId])
  @@map("collection_items")
}

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model FollowRequest {
  id         String              @id @default(uuid())
  fromUserId String              @map("from_user_id")
  toUserId   String              @map("to_user_id")
  status     FollowRequestStatus @default(pending)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  fromUser User @relation("FollowRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FollowRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId])
  @@map("follow_requests")
}

// PRD categories: Food, Drinks, Music, Art, Markets, Community
enum Category {
  food
  drinks
  music
  art
  markets
  community
}

enum MediaType {
  photo
}

enum FollowRequestStatus {
  pending
  accepted
  declined
}

enum CollectionVisibility {
  private
  friends
  public
}

enum ItemType {
  spot
  event
}

