# Barrio API — copy to .env and fill in values.
# For Railway: set these in the project Variables tab (no .env file in production).

NODE_ENV=development
PORT=3000

# PostgreSQL (required). For Railway: use the Postgres plugin and DATABASE_URL will be set.
DATABASE_URL=postgresql://user:password@localhost:5432/barrio?schema=public
# Optional: direct URL for migrations (e.g. connection pooling bypass)
# DIRECT_URL=postgresql://user:password@localhost:5432/barrio

# JWT (required). Use a long random string (min 32 chars).
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d

# Supabase (required for auth + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_STORAGE_BUCKET=media

# CORS (optional). For iOS app use * or your Railway URL.
CORS_ORIGIN=*

# Mastra ingest (proxy + Telegram relay to workflow service)
# MASTRA_API_URL=https://your-mastra-service.up.railway.app
# MASTRA_SERVER_TOKEN=generate-once-paste-same-value-in-portal-mastra-Railway-service

# Telegram ingest bot (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_ID=

# Public API URL (with /api) — used by bot:set-webhook and batch runner in production
# PORTAL_API_URL=https://your-api.up.railway.app/api

# Unsplash (for BCN mock seeder — get key from unsplash.com/oauth/applications)
UNSPLASH_ACCESS_KEY=

# Optional
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_MAPS_API_KEY=
