{
  "name": "barrio-server",
  "version": "1.0.0",
  "description": "Backend API for Barrio - Hyperlocal Events App",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "check-deps": "node scripts/check-dependencies.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-admin-static.mjs",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed:bcn": "tsx prisma/seed-bcn-mock.ts",
    "seed:bcn:events": "tsx prisma/seed-bcn-events-extra.ts",
    "batch": "tsx src/tools/ingest/batch.ts",
    "bot:dev": "tsx src/tools/ingest/bot-dev.ts",
    "bot:set-webhook": "tsx src/tools/ingest/set-webhook.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prepare": "cd .. && husky install server/.husky",
    "tunnel": "ngrok http 3000",
    "audit": "npm audit --audit-level=high",
    "security-check": "npm audit"
  },
  "keywords": [
    "events",
    "hyperlocal",
    "maps",
    "supabase"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "bonjour-service": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "grammy": "^1.41.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^8.17.2",
    "pino-http": "^8.6.0",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^10.3.1",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
